# Neon PostgreSQL connection string
# Get this from https://console.neon.tech → your project → Connection Details
# Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# better-auth secret (min 32 chars) — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Production base URL (no trailing slash) — used by the oAuthProxy plugin on the server
# to route OAuth flows through production. Only this URL needs to be registered in
# Google Cloud Console.
BETTER_AUTH_URL=

# Google OAuth credentials
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
