# Neon PostgreSQL connection string
# Get this from https://console.neon.tech → your project → Connection Details
# Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# better-auth secret (min 32 chars) — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Production base URL (no trailing slash) — use the same value in all environments,
# including local dev and Netlify deploy previews. Deploy previews are trusted via
# trustedOrigins in auth.ts; only this URL needs to be registered in Google Cloud Console.
BETTER_AUTH_URL=

# Public production base URL — same value as BETTER_AUTH_URL, exposed to the browser
# so the auth client always points to production even from deploy previews.
PUBLIC_BETTER_AUTH_URL=

# Google OAuth credentials
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
